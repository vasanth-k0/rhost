{
    "type": "daemon",
    "readonly": false,
    "dir": "app/apps/mongodb",
    "image": "mongo:latest",
    "ports": {
        "host": 27017,
        "container": 27017
    },
    "env": {
        "MONGO_INITDB_ROOT_USERNAME" : "root",
        "MONGO_INITDB_ROOT_PASSWORD" : "root"
    },
    "volumes": {
        "host": "app/storage/internal/user/admin/apps/mongodb",
        "container" : "/data/db"
    }
}
{
    "type": "daemon",
    "readonly": false,
    "autorun" : true,
    "dir": "app/apps/mongodb",
    "image": "mongo:latest",
    "ports": {
        "host": 27017,
        "container": 27017,
        "tty": 7172
    },
    "env": {
        "MONGO_INITDB_ROOT_USERNAME" : "root",
        "MONGO_INITDB_ROOT_PASSWORD" : "root"
    },
    "volumes": {
        "db" : {
                "host": "./server/app/storage/internal/user/admin/apps/mongodb",
                "container" : "/data/db"
            },
        "log":{
                "host": "./server/app/storage/internal/user/admin/apps/mongodb/logs/",
                "container" : "/var/log/mongodb/"
        }
    }
}